[node name="TabContainer" type="TabContainer" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3
theme_override_fonts/font = ExtResource("3_font_semi")
tab_alignment = 1

[node name="OBJECTIVE" type="RichTextLabel" parent="MarginContainer/VBoxContainer/TabContainer"]
layout_mode = 2
theme_override_fonts/normal_font = ExtResource("3_font_semi")
theme_override_font_sizes/normal_font_size = 20
bbcode_enabled = true
text = "
[color=#ff00ff][b]> MISSION OVERVIEW[/b][/color]
The atmospheric pressure is rising. Your base is failing. 

[color=#00ffff][b]> PROTOCOL[/b][/color]
1. Build a pressurized network of pipes.
2. Maintain the integrity of the base.
3. Stabilize the environment before the gauge hits [color=#ff4444]100%[/color]."

[node name="CONTROLS" type="RichTextLabel" parent="MarginContainer/VBoxContainer/TabContainer"]
visible = false
layout_mode = 2
theme_override_fonts/normal_font = ExtResource("3_font_semi")
theme_override_font_sizes/normal_font_size = 20
bbcode_enabled = true
text = "
[color=#ff8800][b]> NAVIGATION[/b][/color]
- [b]WASD / Arrows[/b]: Pan Camera
- [b]Scroll[/b]: Zoom View

[color=#ff8800][b]> LOGISTICS[/b][/color]
- [b]Left Click[/b]: Place Pipe / Interact
- [b]Right Click / R[/b]: Rotate Piece
- [b]ESC[/b]: System Pause"

[node name="RESOURCES" type="RichTextLabel" parent="MarginContainer/VBoxContainer/TabContainer"]
visible = false
layout_mode = 2
theme_override_fonts/normal_font = ExtResource("3_font_semi")
theme_override_font_sizes/normal_font_size = 20
bbcode_enabled = true
text = "
[color=#c8ff00][b]> DATA[/b][/color]
Earned through successful pipe connections. Required for base UPLINK (Save).

[color=#c8ff00][b]> REPAIR RESERVE[/b][/color]
Your safety net. Automated systems use this fund to fix leaks instantly. If this hits 0, you must repair manually."

[node name="BackButton" parent="MarginContainer/VBoxContainer" instance=ExtResource("4_button")]
custom_minimum_size = Vector2(200, 50)
layout_mode = 2
size_flags_horizontal = 4
text = "RETURN TO MENU"

